# Copy this file to ".env" at the repo root and fill in real values.
# NEVER commit your real .env. NEVER hardcode these in source code.

# Required: your Claude API key (https://platform.claude.com -> API keys)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Model to use across Days 2–5 labs (override to try different models)
# claude-sonnet-4-6  — recommended: balanced quality and cost
# claude-haiku-4-5   — fastest and cheapest; good for iteration
# claude-opus-4-8    — highest capability; use for complex tasks
ANTHROPIC_MODEL=claude-sonnet-4-6

# Required for Module 6 (RAG) embeddings via OpenAI
# (https://platform.openai.com -> API keys)
OPENAI_API_KEY=sk-your-openai-key-here

# Optional: turn on SDK debug logging when troubleshooting (debug | info)
# ANTHROPIC_LOG=info
