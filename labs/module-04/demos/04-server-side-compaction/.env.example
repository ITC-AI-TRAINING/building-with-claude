# Copy this file to ".env" in this same folder and fill in your real key.
# NEVER commit your real .env — it is already covered by the repo's root .gitignore.

ANTHROPIC_API_KEY=sk-ant-your-key-here

# Required in THIS file specifically — do not skip creating a local .env here.
# Compaction requires a model that supports it: claude-sonnet-4-6, claude-sonnet-5,
# claude-opus-4-6, claude-opus-4-7, claude-opus-4-8, claude-fable-5. If you don't
# create a .env in this folder, load_dotenv() will fall back to the repo root's
# .env, which sets ANTHROPIC_MODEL=claude-haiku-4-5 for cost reasons across Days
# 2-5 — Haiku does NOT support compaction and the script will fail with a 400.
ANTHROPIC_MODEL=claude-sonnet-4-6
