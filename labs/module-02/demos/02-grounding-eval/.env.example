# Copy this file to ".env" in this same folder and fill in your real key.
# NEVER commit your real .env — it is already covered by the repo's root .gitignore.
# Not needed at all for --dry-run mode.

ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional — override the model this demo uses (defaults to claude-haiku-4-5)
ANTHROPIC_MODEL=claude-haiku-4-5
