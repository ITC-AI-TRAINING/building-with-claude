# Copy this file to ".env" in this same folder and fill in your real keys.
# NEVER commit your real .env — it is already covered by the repo's root .gitignore.

ANTHROPIC_API_KEY=sk-ant-your-key-here
OPENAI_API_KEY=sk-your-openai-key-here

# Optional — override the model / embedding model this demo uses
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
